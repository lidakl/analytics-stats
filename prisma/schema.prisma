generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  }

model users {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  name       String?
  plan_tier  String   @default("starter")
  created_at DateTime @default(now())
}

model daily_usage_events {
  id           Int       @id @default(autoincrement())
  user_id      Int
  date_key     String    // "YYYY-MM-DD"
  request_id   String
  status       String    // "reserved" | "committed"
  reserved_at  DateTime  @default(now())
  committed_at DateTime?
  created_at   DateTime  @default(now())

  @@index([user_id, date_key])
}

model daily_usage_cache {
  id              Int      @id @default(autoincrement())
  user_id         Int
  date_key        String   // "YYYY-MM-DD"
  committed_count Int      @default(0)
  last_updated_at DateTime @default(now()) @updatedAt

  @@unique([user_id, date_key])
  @@index([user_id])
}